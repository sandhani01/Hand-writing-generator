HANDWRITING_API_TITLE=Handwritten Notes Backend
HANDWRITING_AUTH_MODE=supabase
HANDWRITING_SUPABASE_URL=https://<your-project-ref>.supabase.co
HANDWRITING_AUTH_JWT_ISSUER=
HANDWRITING_AUTH_JWT_AUDIENCE=
HANDWRITING_AUTH_JWT_JWKS_URL=
HANDWRITING_AUTH_JWT_SECRET=
HANDWRITING_AUTH_JWT_ALGORITHMS=RS256,ES256,HS256
HANDWRITING_AUTH_SUBJECT_CLAIM=sub
HANDWRITING_AUTH_EMAIL_CLAIM=email
HANDWRITING_DEV_USER_ID=demo-user
HANDWRITING_DEV_USER_EMAIL=demo-user@local.dev
HANDWRITING_DATA_DIR=
HANDWRITING_WORKSPACES_DIR=
HANDWRITING_TEMP_DIR=
HANDWRITING_WORKSPACE_TTL_HOURS=24
HANDWRITING_MAX_ALPHABET_DATASETS=5
HANDWRITING_MAX_CODING_DATASETS=3
HANDWRITING_MAX_BACKGROUNDS=1
HANDWRITING_MAX_SAVED_RENDERS=3
HANDWRITING_DEFAULT_BACKGROUND_PATH=
