HANDWRITING_API_TITLE=Handwritten Notes Backend

# Auth provider
HANDWRITING_AUTH_MODE=supabase
HANDWRITING_SUPABASE_URL=https://<your-project-ref>.supabase.co
# Optional overrides (usually derived automatically from HANDWRITING_SUPABASE_URL)
HANDWRITING_AUTH_JWT_ISSUER=
HANDWRITING_AUTH_JWT_AUDIENCE=
HANDWRITING_AUTH_JWT_JWKS_URL=
HANDWRITING_AUTH_JWT_ALGORITHMS=RS256,ES256

# Hosted database (Supabase Postgres transaction/session pooler URL)
HANDWRITING_DATABASE_URL=postgresql+psycopg://postgres.<project-ref>:<db-password>@<host>:6543/postgres

# Object storage (Cloudflare R2 S3-compatible API)
HANDWRITING_STORAGE_BACKEND=s3
HANDWRITING_STORAGE_PREFIX=handwritten-notes
HANDWRITING_STORAGE_BUCKET=<r2-bucket-name>
HANDWRITING_STORAGE_REGION=auto
HANDWRITING_STORAGE_ENDPOINT_URL=https://<account-id>.r2.cloudflarestorage.com
HANDWRITING_STORAGE_ACCESS_KEY_ID=<r2-access-key-id>
HANDWRITING_STORAGE_SECRET_ACCESS_KEY=<r2-secret-access-key>
HANDWRITING_STORAGE_USE_SSL=true

# Queue + worker
HANDWRITING_JOB_BACKEND=celery
HANDWRITING_REDIS_URL=redis://:<redis-password>@<redis-host>:6379/0
HANDWRITING_CELERY_BROKER_URL=
HANDWRITING_CELERY_RESULT_BACKEND=
HANDWRITING_CELERY_TASK_ALWAYS_EAGER=false
HANDWRITING_JOB_QUEUE_NAME=handwriting
HANDWRITING_JOB_WORKERS=2

# Product limits
HANDWRITING_MAX_ALPHABET_DATASETS=5
HANDWRITING_MAX_CODING_DATASETS=3
HANDWRITING_MAX_BACKGROUNDS=1
HANDWRITING_MAX_SAVED_RENDERS=3

# Backend / frontend origins
HANDWRITING_CORS_ORIGINS=https://<your-frontend-domain>
